<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แก๊งคำศัพท์แสนสนุก 🧸✨</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&family=Noto+Sans+Thai:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Fredoka', 'Noto Sans Thai', sans-serif;
            background-color: #fef08a; 
            background-image: radial-gradient(#fef08a 20%, transparent 20%), radial-gradient(#fde047 20%, transparent 20%);
            background-size: 30px 30px;
            background-position: 0 0, 15px 15px;
        }
        .bouncy {
            animation: bounce 0.6s infinite alternate;
        }
        @keyframes bounce {
            from { transform: translateY(0); }
            to { transform: translateY(-8px); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4">

    <div class="w-full max-w-xl bg-white rounded-3xl shadow-2xl border-4 border-sky-400 p-6 md:p-8 relative overflow-hidden">
        
        <div class="absolute -top-6 -right-6 w-16 h-16 bg-emerald-300 rounded-full opacity-40 blur-sm"></div>
        <div class="absolute -bottom-6 -left-6 w-20 h-20 bg-purple-300 rounded-full opacity-40 blur-sm"></div>

        <div class="text-center mb-6">
            <h1 class="text-3xl md:text-4xl font-bold text-sky-500 inline-block bouncy">
                🧸 แก๊งคำศัพท์แสนสนุก 🦁
            </h1>
            <p class="text-gray-500 text-sm mt-2">มาทายคำศัพท์ภาษาอังกฤษสะสมดาวกันเถอะ!</p>
        </div>

        <div id="setup-screen" class="space-y-6">
            <label class="block text-xl font-bold text-indigo-600 text-center mb-2">✨ น้องๆ อยากเล่นหมวดไหนเลือกเลยจ้า ✨</label>
            
            <div class="grid grid-cols-2 gap-4">
                <button onclick="startGame('animals')" class="p-4 bg-amber-100 hover:bg-amber-200 border-b-4 border-amber-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🦁</span>
                    <span class="font-bold text-amber-800 text-sm md:text-base">หมวดสัตว์น่ารัก</span>
                </button>
                <button onclick="startGame('fruits')" class="p-4 bg-rose-100 hover:bg-rose-200 border-b-4 border-rose-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🍓</span>
                    <span class="font-bold text-rose-800 text-sm md:text-base">หมวดผลไม้แสนอร่อย</span>
                </button>
                <button onclick="startGame('colors')" class="p-4 bg-purple-100 hover:bg-purple-200 border-b-4 border-purple-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🎨</span>
                    <span class="font-bold text-purple-800 text-sm md:text-base">หมวดสีและรูปร่าง</span>
                </button>
                <button onclick="startGame('objects')" class="p-4 bg-emerald-100 hover:bg-emerald-200 border-b-4 border-emerald-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🎒</span>
                    <span class="font-bold text-emerald-800 text-sm md:text-base">หมวดสิ่งของรอบตัว</span>
                </button>
                <button onclick="startGame('food')" class="p-4 bg-orange-100 hover:bg-orange-200 border-b-4 border-orange-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🍰</span>
                    <span class="font-bold text-orange-800 text-sm md:text-base">หมวดอาหารเครื่องดื่ม</span>
                </button>
                <button onclick="startGame('vehicles')" class="p-4 bg-blue-100 hover:bg-blue-200 border-b-4 border-blue-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🚗</span>
                    <span class="font-bold text-blue-800 text-sm md:text-base">หมวดยานพาหนะ</span>
                </button>
                <button onclick="startGame('body')" class="p-4 bg-pink-100 hover:bg-pink-200 border-b-4 border-pink-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">💪</span>
                    <span class="font-bold text-pink-800 text-sm md:text-base">หมวดร่างกายของเรา</span>
                </button>
                <button onclick="startGame('weather')" class="p-4 bg-sky-100 hover:bg-sky-200 border-b-4 border-sky-400 rounded-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center gap-1">
                    <span class="text-3xl">🌈</span>
                    <span class="font-bold text-sky-800 text-sm md:text-base">หมวดสภาพอากาศ</span>
                </button>
            </div>
        </div>

        <div id="game-screen" class="hidden space-y-6">
            <div class="flex justify-between items-center bg-slate-50 p-3 rounded-2xl border border-slate-200 font-bold text-sm">
                <div class="flex gap-4">
                    <span class="text-amber-500">⭐ ดาวสะสม: <span id="score-display">0</span></span>
                    <span class="text-rose-500">🔥 คอมโบ: <span id="streak-display">0</span></span>
                </div>
                <button onclick="goBack()" class="px-3 py-1 bg-slate-200 hover:bg-slate-300 text-slate-600 rounded-xl text-xs transition-colors">
                    🏠 เปลี่ยนหมวด
                </button>
            </div>

            <div class="bg-gradient-to-br from-sky-400 to-indigo-500 rounded-3xl p-8 text-center text-white relative shadow-inner">
                <span id="vocab-emoji" class="text-5xl block mb-2">✨</span>
                <h2 id="vocab-english" class="text-4xl md:text-5xl font-bold tracking-wide uppercase drop-shadow-md">
                    HELLO
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="choices-container">
                </div>

            <div id="result-box" class="hidden p-4 rounded-2xl border-2 text-center text-lg font-bold transition-all transform scale-100">
                <p id="result-text">ข้อความเฉลย</p>
                <button onclick="nextQuestion()" class="mt-3 px-6 py-2 bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-md hover:bg-indigo-700 transition-colors">
                    ลุยข้อต่อไป! ➡️
                </button>
            </div>
        </div>

    </div>

    <script>
        // คลังคำศัพท์สมบูรณ์ครบทุกหมวดหมู่
        const vocabData = {
            animals: [
                { eng: "cat", th: "แมว", emoji: "🐱" },
                { eng: "dog", th: "สุนัข", emoji: "🐶" },
                { eng: "lion", th: "สิงโต", emoji: "🦁" },
                { eng: "elephant", th: "ช้าง", emoji: "🐘" },
                { eng: "rabbit", th: "กระต่าย", emoji: "🐰" },
                { eng: "monkey", th: "ลิง", emoji: "🐵" },
                { eng: "bird", th: "นก", emoji: "🐦" },
                { eng: "fish", th: "ปลา", emoji: "🐟" },
                { eng: "bear", th: "หมี", emoji: "🐻" },
                { eng: "tiger", th: "เสือ", emoji: "🐯" },
                { eng: "giraffe", th: "ยีราฟ", emoji: "🦒" },
                { eng: "zebra", th: "ม้าลาย", emoji: "🦓" },
                { eng: "pig", th: "หมู", emoji: "🐷" },
                { eng: "cow", th: "วัว", emoji: "🐮" },
                { eng: "chicken", th: "ไก่", emoji: "🐔" },
                { eng: "duck", th: "เป็ด", emoji: "🦆" },
                { eng: "horse", th: "ม้า", emoji: "🐴" },
                { eng: "sheep", th: "แกะ", emoji: "🐑" },
                { eng: "turtle", th: "เต่า", emoji: "🐢" },
                { eng: "frog", th: "กบ", emoji: "🐸" }
            ],
            fruits: [
                { eng: "apple", th: "แอปเปิ้ล", emoji: "🍎" },
                { eng: "banana", th: "กล้วย", emoji: "🍌" },
                { eng: "watermelon", th: "แตงโม", emoji: "🍉" },
                { eng: "strawberry", th: "สตรอว์เบอร์รี่", emoji: "🍓" },
                { eng: "orange", th: "ส้ม", emoji: "🍊" },
                { eng: "grape", th: "องุ่น", emoji: "🍇" },
                { eng: "mango", th: "มะม่วง", emoji: "🥭" },
                { eng: "coconut", th: "มะพร้าว", emoji: "🥥" },
                { eng: "pineapple", th: "สับปะรด", emoji: "🍍" },
                { eng: "papaya", th: "มะละกอ", emoji: "🥭" },
                { eng: "durian", th: "ทุเรียน", emoji: "🫓" },
                { eng: "mangosteen", th: "มังคุด", emoji: "🍇" },
                { eng: "cherry", th: "เชอร์รี่", emoji: "🍒" },
                { eng: "peach", th: "ลูกพีช", emoji: "🍑" },
                { eng: "lemon", th: "มะนาวเหลือง", emoji: "🍋" },
                { eng: "lime", th: "มะนาวเขียว", emoji: "🟢" },
                { eng: "melon", th: "เมลอน", emoji: "🍈" },
                { eng: "pear", th: "ลูกแพร์", emoji: "🍐" },
                { eng: "avocado", th: "อะโวคาโด", emoji: "🥑" },
                { eng: "kiwi", th: "กีวี่", emoji: "🥝" }
            ],
            colors: [
                { eng: "red", th: "สีแดง", emoji: "🔴" },
                { eng: "blue", th: "สีน้ำเงิน", emoji: "🔵" },
                { eng: "green", th: "สีเขียว", emoji: "🟢" },
                { eng: "yellow", th: "สีเหลือง", emoji: "🟡" },
                { eng: "pink", th: "สีชมพู", emoji: "🌸" },
                { eng: "purple", th: "สีม่วง", emoji: "🟣" },
                { eng: "orange", th: "สีส้ม", emoji: "🟠" },
                { eng: "black", th: "สีดำ", emoji: "⚫" },
                { eng: "white", th: "สีขาว", emoji: "⚪" },
                { eng: "brown", th: "สีน้ำตาล", emoji: "🟤" },
                { eng: "gray", th: "สีเทา", emoji: "⚪" },
                { eng: "circle", th: "วงกลม", emoji: "⭕" },
                { eng: "square", th: "สี่เหลี่ยมจัตุรัส", emoji: "⏹️" },
                { eng: "triangle", th: "สามเหลี่ยม", emoji: "🔺" },
                { eng: "star", th: "ดวงดาว", emoji: "⭐" },
                { eng: "heart", th: "หัวใจ", emoji: "❤️" }
            ],
            objects: [
                { eng: "book", th: "หนังสือ", emoji: "📖" },
                { eng: "pencil", th: "ดินสอ", emoji: "✏️" },
                { eng: "bag", th: "กระเป๋า", emoji: "🎒" },
                { eng: "chair", th: "เก้าอี้", emoji: "🪑" },
                { eng: "table", th: "โต๊ะ", emoji: "🪵" },
                { eng: "clock", th: "นาฬิกา", emoji: "⏰" },
                { eng: "umbrella", th: "ร่ม", emoji: "☂️" },
                { eng: "shoes", th: "รองเท้า", emoji: "👟" },
                { eng: "computer", th: "คอมพิวเตอร์", emoji: "💻" },
                { eng: "phone", th: "โทรศัพท์", emoji: "📱" },
                { eng: "ruler", th: "ไม้บรรทัด", emoji: "📏" },
                { eng: "eraser", th: "ยางลบ", emoji: "🧼" },
                { eng: "scissors", th: "กรรไกร", emoji: "✂️" },
                { eng: "crayon", th: "สีเทียน", emoji: "🖍️" },
                { eng: "window", th: "หน้าต่าง", emoji: "🪟" },
                { eng: "door", th: "ประตู", emoji: "🚪" },
                { eng: "fan", th: "พัดลม", emoji: "🪭" },
                { eng: "lamp", th: "โคมไฟ", emoji: "💡" },
                { eng: "key", th: "กุญแจ", emoji: "🔑" },
                { eng: "bed", th: "เตียงนอน", emoji: "🛏️" }
            ],
            food: [
                { eng: "milk", th: "นม", emoji: "🥛" },
                { eng: "bread", th: "ขนมปัง", emoji: "🍞" },
                { eng: "egg", th: "ไข่", emoji: "🥚" },
                { eng: "rice", th: "ข้าว", emoji: "🍚" },
                { eng: "water", th: "น้ำเปล่า", emoji: "💧" },
                { eng: "juice", th: "น้ำผลไม้", emoji: "🧃" },
                { eng: "cake", th: "เค้ก", emoji: "🍰" },
                { eng: "ice cream", th: "ไอศกรีม", emoji: "🍦" },
                { eng: "candy", th: "ลูกอม", emoji: "🍬" },
                { eng: "chocolate", th: "ช็อกโกแลต", emoji: "🍫" },
                { eng: "pizza", th: "พิซซ่า", emoji: "🍕" },
                { eng: "burger", th: "แฮมเบอร์เกอร์", emoji: "🍔" },
                { eng: "soup", th: "ซุป", emoji: "🥣" },
                { eng: "fish", th: "เนื้อปลา", emoji: "🐟" },
                { eng: "meat", th: "เนื้อสัตว์", emoji: "🥩" },
                { eng: "cheese", th: "ชีส", emoji: "🧀" },
                { eng: "donut", th: "โดนัท", emoji: "🍩" },
                { eng: "cookie", th: "คุกกี้", emoji: "🍪" },
                { eng: "honey", th: "น้ำผึ้ง", emoji: "🍯" },
                { eng: "tea", th: "น้ำชา", emoji: "🍵" }
            ],
            vehicles: [
                { eng: "car", th: "รถยนต์", emoji: "🚗" },
                { eng: "bus", th: "รถเมล์/รถบัส", emoji: "🚌" },
                { eng: "bicycle", th: "รถจักรยาน", emoji: "🚲" },
                { eng: "motorcycle", th: "รถจักรยานยนต์", emoji: "🏍️" },
                { eng: "train", th: "รถไฟ", emoji: "🚂" },
                { eng: "airplane", th: "เครื่องบิน", emoji: "✈️" },
                { eng: "boat", th: "เรือ", emoji: "⛵" },
                { eng: "ship", th: "เรือสินค้าขนาดใหญ่", emoji: "🚢" },
                { eng: "helicopter", th: "เฮลิคอปเตอร์", emoji: "🚁" },
                { eng: "rocket", th: "จรวด", emoji: "🚀" },
                { eng: "truck", th: "รถบรรทุก", emoji: "🚚" },
                { eng: "ambulance", th: "รถพยาบาล", emoji: "🚑" },
                { eng: "taxi", th: "รถแท็กซี่", emoji: "🚕" },
                { eng: "van", th: "รถตู้", emoji: "🚐" },
                { eng: "subway", th: "รถไฟใต้ดิน", emoji: "🚇" }
            ],
            body: [
                { eng: "head", th: "ศีรษะ/หัว", emoji: "👤" },
                { eng: "hair", th: "เส้นผม", emoji: "💇" },
                { eng: "eye", th: "ดวงตา", emoji: "👁️" },
                { eng: "ear", th: "ใบหู", emoji: "👂" },
                { eng: "nose", th: "จมูก", emoji: "👃" },
                { eng: "mouth", th: "ปาก", emoji: "👄" },
                { eng: "tooth", th: "ฟัน", emoji: "🦷" },
                { eng: "hand", th: "มือ", emoji: "✋" },
                { eng: "arm", th: "แขน", emoji: "💪" },
                { eng: "leg", th: "ขา", emoji: "🦵" },
                { eng: "foot", th: "เท้า", emoji: "🦶" },
                { eng: "finger", th: "นิ้วมือ", emoji: "☝️" },
                { eng: "shoulder", th: "หัวไหล่", emoji: "🤷" },
                { eng: "knee", th: "หัวเข่า", emoji: "🦵" },
                { eng: "face", th: "ใบหน้า", emoji: "😊" }
            ],
            weather: [
                { eng: "sun", th: "พระอาทิตย์", emoji: "☀️" },
                { eng: "moon", th: "พระจันทร์", emoji: "🌙" },
                { eng: "cloud", th: "ก้อนเมฆ", emoji: "☁️" },
                { eng: "rain", th: "ฝน", emoji: "🌧️" },
                { eng: "snow", th: "หิมะ", emoji: "❄️" },
                { eng: "wind", th: "ลม", emoji: "💨" },
                { eng: "sky", th: "ท้องฟ้า", emoji: "🌌" },
                { eng: "rainbow", th: "สายรุ้ง", emoji: "🌈" },
                { eng: "storm", th: "พายุ", emoji: "⛈️" },
                { eng: "tree", th: "ต้นไม้", emoji: "🌳" },
                { eng: "flower", th: "ดอกไม้", emoji: "🌸" },
                { eng: "sea", th: "ทะเล", emoji: "🌊" }
            ]
        };

        let currentCategory = '';
        let currentWord = {};
        let score = 0;
        let streak = 0;
        let isAnswered = false;

        function startGame(category) {
            currentCategory = category;
            document.getElementById('setup-screen').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            nextQuestion();
        }

        function goBack() {
            document.getElementById('game-screen').classList.add('hidden');
            document.getElementById('setup-screen').classList.remove('hidden');
            score = 0;
            streak = 0;
            document.getElementById('score-display').innerText = score;
            document.getElementById('streak-display').innerText = streak;
        }

        function nextQuestion() {
            isAnswered = false;
            document.getElementById('result-box').classList.add('hidden');
            
            const wordList = vocabData[currentCategory];
            const randomIndex = Math.floor(Math.random() * wordList.length);
            currentWord = wordList[randomIndex];

            document.getElementById('vocab-english').innerText = currentWord.eng;
            document.getElementById('vocab-emoji').innerText = currentWord.emoji;

            let choices = [currentWord.th];
            
            while(choices.length < 4) {
                let randomWrongWord = wordList[Math.floor(Math.random() * wordList.length)].th;
                if(!choices.includes(randomWrongWord)) {
                    choices.push(randomWrongWord);
                }
            }

            choices.sort(() => Math.random() - 0.5);

            const btnColors = [
                'bg-emerald-100 hover:bg-emerald-200 border-emerald-400 text-emerald-800',
                'bg-sky-100 hover:bg-sky-200 border-sky-400 text-sky-800',
                'bg-pink-100 hover:bg-pink-200 border-pink-400 text-pink-800',
                'bg-amber-100 hover:bg-amber-200 border-amber-400 text-amber-800'
            ];

            const container = document.getElementById('choices-container');
            container.innerHTML = ''; 

            choices.forEach((choice, index) => {
                const button = document.createElement('button');
                button.className = `choice-btn w-full p-4 text-xl font-bold rounded-2xl border-b-4 transition-all transform active:scale-95 ${btnColors[index]}`;
                button.innerText = choice;
                button.onclick = () => selectAnswer(choice, button);
                container.appendChild(button);
            });
        }

        function selectAnswer(selectedChoice, selectedButton) {
            if (isAnswered) return; 
            isAnswered = true;

            const resultBox = document.getElementById('result-box');
            const resultText = document.getElementById('result-text');

            document.querySelectorAll('.choice-btn').forEach(btn => {
                btn.disabled = true;
                if(btn.innerText === currentWord.th) {
                    btn.className = "w-full p-4 text-xl font-bold rounded-2xl border-b-4 bg-green-500 border-green-700 text-white";
                }
            });

            if (selectedChoice === currentWord.th) {
                score += 1;
                streak += 1;
                resultBox.className = "p-4 rounded-2xl border-2 text-center text-lg font-bold bg-emerald-50 border-emerald-300 text-emerald-700";
                resultText.innerHTML = `🎉 เก่งมากเลย! ตอบถูกเป๊ะ! <br><span class="text-2xl">${currentWord.eng} = ${currentWord.th}</span>`;
            } else {
                streak = 0; 
                selectedButton.className = "w-full p-4 text-xl font-bold rounded-2xl border-b-4 bg-rose-500 border-rose-700 text-white"; 
                resultBox.className = "p-4 rounded-2xl border-2 text-center text-lg font-bold bg-rose-50 border-rose-300 text-rose-700";
                resultText.innerHTML = `🧸 ไม่เป็นไรน้า ลองดูคำเฉลยสีเขียวข้างบนจ้า <br><span class="text-2xl text-indigo-600">${currentWord.eng} แปลว่า "${currentWord.th}"</span>`;
            }

            document.getElementById('score-display').innerText = score;
            document.getElementById('streak-display').innerText = streak;
            resultBox.classList.remove('hidden');
        }
    </script>
</body>
</html>
